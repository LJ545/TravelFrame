# TravelFrame server — environment configuration
# Copy this file to .env and fill in any values you want to override.
# All variables have safe defaults; .env is not required for a basic local setup.

# ── Network ──────────────────────────────────────────────────────────────────

# TCP port the server listens on.
PORT=3001

# Bind address. Use 127.0.0.1 to accept only local connections.
HOST=0.0.0.0

# Set to true when running behind a reverse proxy (nginx, Caddy, Cloudflare).
TRUST_PROXY=false

# Allowed CORS origins. Use * for local dev; set your real domain in production.
# Multiple origins: CORS_ORIGINS=https://myframe.example.com,https://www.myframe.example.com
CORS_ORIGINS=*

# ── Storage ───────────────────────────────────────────────────────────────────

# Directory where per-device state, images, and templates are stored.
# Created automatically if it does not exist. Use an absolute path in production.
DATA_DIR=./data

# ── Backups ───────────────────────────────────────────────────────────────────

# Where daily backup archives are written.
BACKUP_DIR=./backups

# Cron schedule (UTC) for the daily backup. Default: 03:17 UTC.
BACKUP_CRON=17 3 * * *

# How many days of backups to keep on disk before pruning.
BACKUP_RETENTION_DAYS=30

# Optional rclone remote for off-site copies (e.g. "s3:my-bucket/travelframe").
# Leave blank to skip remote upload.
# BACKUP_REMOTE=

# ── Rate limiting ─────────────────────────────────────────────────────────────

# Maximum requests per IP per window.
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW=1 minute

# ── Uploads ───────────────────────────────────────────────────────────────────

# Maximum BMP upload size in bytes. 800x480 grayscale is ~376 KiB; 2 MiB is the safe cap.
IMAGE_MAX_BYTES=2097152

# Maximum SVG template upload size in bytes. Full world-map templates can exceed 2 MiB.
TEMPLATE_MAX_BYTES=10485760

# ── Logging ───────────────────────────────────────────────────────────────────

# Pino log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

NODE_ENV=production
